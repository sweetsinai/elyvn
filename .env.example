# === CORE ===
NODE_ENV=development
PORT=3001
MCP_PORT=8000
DATABASE_PATH=./elyvn.db

# === SECURITY ===
ELYVN_API_KEY=              # Required in production — protects all API endpoints + dashboard login
CORS_ORIGINS=               # Comma-separated allowed origins (e.g. https://yourdomain.com). Leave empty for dev.

# === ANTHROPIC (Claude) ===
ANTHROPIC_API_KEY=

# === RETELL AI ===
RETELL_API_KEY=

# === TWILIO ===
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# === CAL.COM ===
CALCOM_API_KEY=

# === SMTP (Engine 2 — cold email) ===
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM_NAME=Sohan from ELYVN

# === GOOGLE MAPS (Engine 2 — scraping) ===
GOOGLE_MAPS_API_KEY=

# === IMAP (Engine 2 — reply checking) ===
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=
IMAP_PASS=

# === TELEGRAM BOT ===
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_ADMIN_CHAT_ID=      # Your personal chat ID for critical error alerts (get from @userinfobot)

# === MY BOOKING LINK (Engine 2 — for prospects to book with me) ===
MY_CALCOM_LINK=https://cal.com/sohan/discovery
CALCOM_BOOKING_LINK=https://cal.com/elyvn/demo
CALCOM_EVENT_TYPE_ID=

# === CAN-SPAM COMPLIANCE ===
BUSINESS_ADDRESS=            # Physical mailing address (required by CAN-SPAM for cold emails)

# === STRIPE BILLING ===
STRIPE_SECRET_KEY=           # Stripe secret key (sk_test_... or sk_live_...)
STRIPE_WEBHOOK_SECRET=       # Stripe webhook signing secret (whsec_...)
STRIPE_PRICE_STARTER=        # Optional: Stripe Price ID for Starter plan
STRIPE_PRICE_PRO=            # Optional: Stripe Price ID for Pro plan
STRIPE_PRICE_PREMIUM=        # Optional: Stripe Price ID for Premium plan
APP_URL=https://api.elyvn.net  # Base URL for Stripe redirect URLs

# === AUTH ===
JWT_SECRET=                  # Secret for JWT signing (min 32 chars, generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")

# === TELNYX (DEPRECATED — use Twilio instead) ===
# TELNYX_API_KEY=
# TELNYX_PHONE_NUMBER=
# TELNYX_MESSAGING_PROFILE_ID=

# === OPTIONAL: MONITORING ===
SENTRY_DSN=                  # Sentry error tracking (free tier available)
CLAUDE_MODEL=claude-sonnet-4-20250514  # Claude model for brain/SMS/analysis
