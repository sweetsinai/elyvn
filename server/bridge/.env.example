# Copy this file to .env and fill in your values

# ─── Server ───────────────────────────────────────────────────
# OPTIONAL: Port the bridge server listens on (default: 3001)
PORT=3001

# REQUIRED: Runtime environment — controls HTTPS redirect, error verbosity, etc.
NODE_ENV=production

# ─── Database ─────────────────────────────────────────────────
# REQUIRED: PostgreSQL connection string (Railway Postgres / Supabase recommended)
DATABASE_URL=postgresql://postgres:password@db.xxxx.supabase.co:5432/postgres

# OPTIONAL: Path to SQLite file used when DATABASE_URL is not set
DATABASE_PATH=./elyvn.db

# ─── Supabase ─────────────────────────────────────────────────
# OPTIONAL: Supabase project URL — required for migrate-to-supabase script
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co

# OPTIONAL: Supabase anon/public key (safe server-side with RLS enabled)
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxx

# OPTIONAL: Supabase service role key — bypasses RLS, keep secret, server-side only
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxx

# ─── Auth ─────────────────────────────────────────────────────
# REQUIRED: Secret used to sign and verify JWT tokens (min 32 chars)
JWT_SECRET=your_jwt_secret_here_minimum_32_characters_long

# REQUIRED: Internal API key for authenticating service-to-service requests (min 32 chars)
ELYVN_API_KEY=your_internal_api_key_here_minimum_32_chars

# REQUIRED: 32-byte hex key used to encrypt sensitive fields in the database
ENCRYPTION_KEY=your_32_byte_hex_encryption_key_here

# ─── CORS / URLs ──────────────────────────────────────────────
# REQUIRED: Comma-separated list of allowed CORS origins
CORS_ORIGINS=https://elyvn.ai,http://localhost:3000,http://localhost:5173

# OPTIONAL: Public URL of this service (used in Stripe redirect URLs and email tracking links)
APP_URL=https://api.elyvn.net

# OPTIONAL: Base URL alias (same as APP_URL in most cases)
BASE_URL=https://api.elyvn.net

# OPTIONAL: Set automatically by Railway — public domain of this service
RAILWAY_PUBLIC_DOMAIN=bridge-production.up.railway.app

# OPTIONAL: Set automatically by Railway — environment name (production/staging)
RAILWAY_ENVIRONMENT=production

# ─── Retell AI ────────────────────────────────────────────────
# REQUIRED: Retell AI API key for managing agents and calls
RETELL_API_KEY=key_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# REQUIRED: Webhook secret for validating inbound Retell webhook payloads
RETELL_WEBHOOK_SECRET=your_retell_webhook_secret_here

# ─── Twilio ───────────────────────────────────────────────────
# OPTIONAL: Twilio Account SID
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# REQUIRED in production: Twilio Auth Token for validating inbound SMS/voice webhooks
# Without this, any HTTP client can forge fake Twilio webhooks (dev-only bypass)
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here

# OPTIONAL: Twilio phone number used as outbound caller ID (E.164 format)
TWILIO_PHONE_NUMBER=+12015550100

# ─── Telnyx ───────────────────────────────────────────────────
# OPTIONAL: Telnyx public key for validating inbound webhook signatures
TELNYX_PUBLIC_KEY=your_telnyx_public_key_here

# OPTIONAL: Telnyx API key for outbound messaging
TELNYX_API_KEY=your_telnyx_api_key_here

# OPTIONAL: Telnyx messaging profile ID for SMS sending
TELNYX_MESSAGING_PROFILE_ID=your_telnyx_messaging_profile_id

# ─── Stripe ───────────────────────────────────────────────────
# REQUIRED: Stripe secret key for creating checkout sessions and customers
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# REQUIRED: Stripe webhook signing secret for validating inbound events
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# REQUIRED: Stripe price ID for the Starter plan
STRIPE_PRICE_STARTER=price_xxxxxxxxxxxxxxxxxxxxxxxx

# REQUIRED: Stripe price ID for the Growth plan
STRIPE_PRICE_GROWTH=price_xxxxxxxxxxxxxxxxxxxxxxxx

# REQUIRED: Stripe price ID for the Scale plan
STRIPE_PRICE_SCALE=price_xxxxxxxxxxxxxxxxxxxxxxxx

# ─── Cal.com ──────────────────────────────────────────────────
# OPTIONAL: Cal.com API key for booking management
CALCOM_API_KEY=cal_live_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OPTIONAL: Cal.com webhook secret for validating inbound booking events
CALCOM_WEBHOOK_SECRET=your_calcom_webhook_secret_here

# OPTIONAL: Cal.com booking link shown to prospects by the AI agent
CALCOM_BOOKING_LINK=https://cal.com/yourname/quick

# OPTIONAL: Cal.com event type ID used when creating bookings via the API
CALCOM_EVENT_TYPE_ID=123456

# ─── Anthropic / Claude ───────────────────────────────────────
# REQUIRED: Anthropic API key for Claude AI features
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OPTIONAL: Claude model version to use (default: claude-sonnet-4-20250514)
CLAUDE_MODEL=claude-sonnet-4-20250514

# OPTIONAL: Timeout in milliseconds for Anthropic API calls (default: 30000)
ANTHROPIC_TIMEOUT=30000

# ─── Email (SMTP — outbound) ──────────────────────────────────
# OPTIONAL: SMTP hostname for outbound email
SMTP_HOST=smtp.gmail.com

# OPTIONAL: SMTP port (465 for implicit SSL, 587 for STARTTLS)
SMTP_PORT=465

# OPTIONAL: Set to "true" to use implicit SSL (required for port 465)
SMTP_SECURE=true

# OPTIONAL: SMTP login username / from address
SMTP_USER=you@yourdomain.com

# OPTIONAL: SMTP login password or app-specific password
SMTP_PASS=your_smtp_app_password_here

# OPTIONAL: Display name used in the From header
SMTP_FROM_NAME=Sohan from ELYVN

# OPTIONAL: From email address override (falls back to SMTP_USER if not set)
SMTP_FROM=you@yourdomain.com

# OPTIONAL: Sender name shown in outreach campaign emails (default: Sohan)
OUTREACH_SENDER_NAME=Sohan

# OPTIONAL: Maximum number of outbound campaign emails to send per day (default: 300)
EMAIL_DAILY_LIMIT=300

# ─── Email (IMAP — inbound reply checking) ────────────────────
# OPTIONAL: IMAP server hostname for polling reply inbox (default: imap.gmail.com)
IMAP_HOST=imap.gmail.com

# OPTIONAL: IMAP server port (default: 993)
IMAP_PORT=993

# OPTIONAL: IMAP login username (typically same as SMTP_USER)
IMAP_USER=you@yourdomain.com

# OPTIONAL: IMAP login password or app-specific password
IMAP_PASS=your_imap_app_password_here

# ─── Telegram (Notifications) ─────────────────────────────────
# OPTIONAL: Telegram bot token for sending admin notifications
TELEGRAM_BOT_TOKEN=1234567890:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OPTIONAL: Telegram bot username without the @ prefix
TELEGRAM_BOT_USERNAME=ElyvnBot

# OPTIONAL: Chat ID that receives admin-level alerts and crash notifications
TELEGRAM_ADMIN_CHAT_ID=5919400000

# OPTIONAL: Webhook secret for validating inbound Telegram updates
TELEGRAM_WEBHOOK_SECRET=your_telegram_webhook_secret_here

# ─── Webhook Signing ──────────────────────────────────────────
# OPTIONAL: Secret used to sign and verify outbound webhook payloads (webhookQueue)
WEBHOOK_SIGNING_SECRET=your_webhook_signing_secret_here

# ─── Business Profile ─────────────────────────────────────────
# OPTIONAL: Physical business address included in email footers and AI prompts
BUSINESS_ADDRESS=123 Main St, San Francisco, CA 94105

# ─── Observability ────────────────────────────────────────────
# OPTIONAL: Sentry DSN for error tracking
SENTRY_DSN=https://xxxx@oxxxx.ingest.sentry.io/xxxx

# OPTIONAL: OpenTelemetry OTLP endpoint (e.g. Grafana Cloud, Honeycomb)
OTEL_EXPORTER_OTLP_ENDPOINT=https://otlp.example.com

# OPTIONAL: Set to "true" to disable OpenTelemetry instrumentation entirely
OTEL_DISABLED=false

# ─── Logging ──────────────────────────────────────────────────
# OPTIONAL: Minimum log level — error | warn | info | debug (default: info)
LOG_LEVEL=info

# OPTIONAL: Directory to write rotating log files to (default: ./logs)
LOG_DIR=./logs

# OPTIONAL: Days to retain log files before deletion (default: 7)
LOG_RETENTION_DAYS=30

# OPTIONAL: Path for the audit fallback log when the primary log is unavailable
AUDIT_FALLBACK_LOG=./logs/audit-fallback.log

# ─── Rate Limiting ────────────────────────────────────────────
# OPTIONAL: Rate limit sliding window in milliseconds (default: 60000 = 1 minute)
RATE_LIMIT_WINDOW_MS=60000

# OPTIONAL: Maximum requests allowed per window for the general rate limiter (default: 100)
RATE_LIMIT_MAX_REQUESTS=100

# ─── Timeouts ─────────────────────────────────────────────────
# OPTIONAL: Timeout in milliseconds for outbound fetch/scrape requests (default: 5000)
FETCH_TIMEOUT=5000

# ─── Redis ────────────────────────────────────────────────────
# OPTIONAL: Redis connection URL — used for nonce/CSRF state when set; falls back to in-memory
REDIS_URL=redis://localhost:6379

# ─── Google Maps ──────────────────────────────────────────────
# OPTIONAL: Google Maps API key for geo-enrichment and address lookup features
GOOGLE_MAPS_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Testing ──────────────────────────────────────────────────
# OPTIONAL: Base URL used by integration tests
TEST_BASE_URL=http://localhost:3001

# OPTIONAL: API key used by integration tests
TEST_API_KEY=test_key_for_integration_tests_here
