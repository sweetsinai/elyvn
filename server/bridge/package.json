{
  "name": "elyvn-bridge",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "start": "node index.js",
    "dev": "node --watch index.js",
    "test": "jest --forceExit --passWithNoTests",
    "test:unit": "jest tests/validate.test.js --forceExit",
    "test:integration": "jest tests/endpoints.test.js --forceExit --testTimeout=20000",
    "test:coverage": "jest --coverage",
    "audit:check": "npm audit --omit=dev --audit-level=high",
    "audit": "npm audit --audit-level=high",
    "audit:fix": "npm audit fix",
    "prepare": "husky install"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.0",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.72.0",
    "@opentelemetry/core": "^2.6.1",
    "@opentelemetry/exporter-trace-otlp-http": "^0.214.0",
    "@opentelemetry/sdk-node": "^0.214.0",
    "@sentry/node": "^8.0.0",
    "better-sqlite3": "^11.6.0",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "helmet": "^8.1.0",
    "imapflow": "^1.3.1",
    "ioredis": "^5.3.2",
    "js-yaml": "^4.1.0",
    "mailparser": "^3.9.5",
    "nodemailer": "^8.0.5",
    "pg": "^8.20.0",
    "stripe": "^21.0.1",
    "ws": "^8.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "husky": "^9.0.0",
    "jest": "^29.7.0",
    "lint-staged": "^15.0.0",
    "supertest": "^7.2.2"
  },
  "lint-staged": {
    "*.js": [
      "node --check"
    ]
  }
}
