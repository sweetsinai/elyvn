    {
      "name": "Auth",
      "item": [
        {
          "name": "POST /auth/signup - valid",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/signup",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-Requested-With",
                "value": "XMLHttpRequest"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"email\":\"test@elyvn.net\",\"password\":\"TestPass123!\",\"business_name\":\"Test Biz\",\"owner_name\":\"Test Owner\",\"owner_phone\":\"+14155551234\"}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const j = pm.response.json(); if (pm.response.code === 201) { pm.globals.set('auth_token', j.token); pm.globals.set('client_id', j.clientId); } pm.test('signup ok or duplicate', () => pm.expect([201,409]).to.include(pm.response.code));"
                ]
              }
            }
          ]
        },
        {
          "name": "POST /auth/login - valid",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/login",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-Requested-With",
                "value": "XMLHttpRequest"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"email\":\"test@elyvn.net\",\"password\":\"TestPass123!\"}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const j = pm.response.json(); if (pm.response.code === 200) { pm.globals.set('auth_token', j.token); pm.globals.set('client_id', j.clientId); } pm.test('login ok', () => pm.expect([200,401]).to.include(pm.response.code));"
                ]
              }
            }
          ]
        },
        {
          "name": "POST /auth/login - wrong password",
