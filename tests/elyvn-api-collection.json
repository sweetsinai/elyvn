              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"business_name\":\"Test\",\"owner_phone\":\"+14155551234\",\"plan\":\"invalid\"}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('422 invalid plan', () => pm.response.to.have.status(422));"
                ]
              }
            }
          ]
        },
        {
          "name": "POST /provision - SQL injection attempt",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/provision",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "x-api-key",
                "value": "{{api_key}}"
              },
              {
                "key": "X-Requested-With",
                "value": "XMLHttpRequest"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"business_name\":\"Test'; DROP TABLE clients; --\",\"owner_phone\":\"+14155551234\",\"plan\":\"growth\"}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('SQL injection safely stored, not executed', () => { pm.expect([201,401,403]).to.include(pm.response.code); if (pm.response.code === 201) { pm.expect(pm.response.json().client.business_name).to.include(\"DROP TABLE\"); } });"
                ]
              }
            }
          ]
        },
        {
          "name": "POST /provision - XSS in email",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/provision",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "x-api-key",
                "value": "{{api_key}}"
              },
              {
                "key": "X-Requested-With",
                "value": "XMLHttpRequest"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"business_name\":\"Test\",\"owner_phone\":\"+14155551234\",\"owner_email\":\"<script>alert(1)</script>\",\"plan\":\"growth\"}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('422 xss rejected', () => pm.response.to.have.status(422));"
                ]
              }
            }
          ]
        }
      ]
